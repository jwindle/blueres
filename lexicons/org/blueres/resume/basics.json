{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.basics",
  "defs": {
    "main": {
      "type": "record",
      "description": "Basic personal information for a resume. Singleton record stored with rkey 'self'.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string" },
          "label": { "type": "string", "description": "e.g. Web Developer" },
          "image": { "type": "string", "format": "uri", "description": "URL to a JPEG or PNG image" },
          "email": { "type": "string" },
          "phone": { "type": "string", "description": "e.g. 712-117-2923" },
          "url": { "type": "string", "format": "uri", "description": "Personal homepage" },
          "summary": { "type": "string", "description": "Short 2-3 sentence biography" },
          "location": { "type": "ref", "ref": "#location" },
          "profiles": {
            "type": "array",
            "items": { "type": "ref", "ref": "#profile" }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "required": [],
      "properties": {
        "address": { "type": "string" },
        "postalCode": { "type": "string" },
        "city": { "type": "string" },
        "countryCode": { "type": "string", "description": "ISO-3166-1 ALPHA-2, e.g. US, AU, IN" },
        "region": { "type": "string", "description": "e.g. California" }
      }
    },
    "profile": {
      "type": "object",
      "required": [],
      "properties": {
        "network": { "type": "string", "description": "e.g. Twitter" },
        "username": { "type": "string", "description": "e.g. neutralthoughts" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
