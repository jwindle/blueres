{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.publications",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single publication.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string", "description": "e.g. The World Wide Web" },
          "publisher": { "type": "string", "description": "e.g. IEEE, Computer Magazine" },
          "did": { "type": "string", "format": "did", "description": "Bluesky DID of the publisher, if they have an account" },
          "releaseDate": { "type": "string", "description": "ISO 8601 partial date" },
          "url": { "type": "string", "format": "uri" },
          "summary": { "type": "string", "description": "Short summary of the publication" }
        }
      }
    }
  }
}
