{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.certificates",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single certificate received throughout a professional career.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string", "description": "e.g. Certified Kubernetes Administrator" },
          "date": { "type": "string", "description": "ISO 8601 partial date" },
          "url": { "type": "string", "format": "uri", "description": "Link to certificate" },
          "issuer": { "type": "string", "description": "e.g. CNCF" }
        }
      }
    }
  }
}
