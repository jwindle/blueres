{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.work",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single work experience entry. Each job is stored as a separate record.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string", "description": "Company name, e.g. Facebook" },
          "did": { "type": "string", "format": "did", "description": "Bluesky DID of the company, if they have an account" },
          "location": { "type": "string", "description": "e.g. Menlo Park, CA" },
          "description": { "type": "string", "description": "e.g. Social Media Company" },
          "position": { "type": "string", "description": "e.g. Software Engineer" },
          "url": { "type": "string", "format": "uri" },
          "startDate": { "type": "string", "description": "ISO 8601 partial date, e.g. 2014-06-29 or 2023-04 or 2023" },
          "endDate": { "type": "string", "description": "ISO 8601 partial date. Omit if current position." },
          "summary": { "type": "string", "description": "Overview of responsibilities" },
          "highlights": {
            "type": "array",
            "items": { "type": "string", "description": "e.g. Increased profits by 20%" }
          }
        }
      }
    }
  }
}
