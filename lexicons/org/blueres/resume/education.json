{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.education",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single education entry. Each institution is stored as a separate record.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "institution": { "type": "string", "description": "e.g. Massachusetts Institute of Technology" },
          "did": { "type": "string", "format": "did", "description": "Bluesky DID of the institution, if they have an account" },
          "url": { "type": "string", "format": "uri" },
          "area": { "type": "string", "description": "e.g. Arts" },
          "studyType": { "type": "string", "description": "e.g. Bachelor" },
          "startDate": { "type": "string", "description": "ISO 8601 partial date, e.g. 2014-06-29 or 2023-04 or 2023" },
          "endDate": { "type": "string", "description": "ISO 8601 partial date. Omit if currently enrolled." },
          "score": { "type": "string", "description": "Grade point average, e.g. 3.67/4.0" },
          "courses": {
            "type": "array",
            "description": "Notable courses/subjects",
            "items": { "type": "string", "description": "e.g. H1302 - Introduction to American history" }
          }
        }
      }
    }
  }
}
