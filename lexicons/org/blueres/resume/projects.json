{
  "lexicon": 1,
  "revision": 1,
  "id": "org.blueres.resume.projects",
  "defs": {
    "main": {
      "type": "record",
      "description": "A single career project.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string", "description": "e.g. The World Wide Web" },
          "description": { "type": "string", "description": "Short summary of the project" },
          "highlights": {
            "type": "array",
            "items": { "type": "string" }
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string", "description": "e.g. AngularJS" }
          },
          "startDate": { "type": "string", "description": "ISO 8601 partial date" },
          "endDate": { "type": "string", "description": "ISO 8601 partial date" },
          "url": { "type": "string", "format": "uri" },
          "roles": {
            "type": "array",
            "description": "Your role(s) on this project",
            "items": { "type": "string", "description": "e.g. Team Lead, Speaker, Writer" }
          },
          "entity": { "type": "string", "description": "Relevant company/entity, e.g. greenpeace" },
          "did": { "type": "string", "format": "did", "description": "Bluesky DID of the entity, if they have an account" },
          "type": { "type": "string", "description": "e.g. volunteering, presentation, talk, application, conference" }
        }
      }
    }
  }
}
